model User {
  id       String  @id @default(uuid())
  name     String
  email    String  @unique
  password String
  phone    String?
  address  String?
  image    String?

  role UserRole @default(CUSTOMER)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  gearItems    GearItem[]
  rentalOrders RentalOrder[]
  reviews      Review[]

  @@map("users")
}
