{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,

    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,

    "ignoreDeprecations": "6.0",

    "moduleResolution": "node",

    "resolveJsonModule": true
  },

  "include": ["src"],

  "exclude": ["node_modules"]
}